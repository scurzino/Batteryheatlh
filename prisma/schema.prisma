// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("USER") // 'USER' | 'ADMIN'
  createdAt    DateTime @default(now())

  entries      SohEntry[]
  flags        ModerationFlag[]
  trips        TripLog[]
  notes        VehicleNote[]
}

model Vehicle {
  id           String     @id @default(uuid())
  oem          String
  model        String
  year         Int
  batteryModel String

  entries      SohEntry[]
  trips        TripLog[]
  notes        VehicleNote[]

  @@unique([oem, model, year, batteryModel])
}

model SohEntry {
  id                String   @id @default(uuid())
  userId            String?
  vehicleId         String
  soh               Float
  mileage           Float
  region            String
  usageType         String
  chargeType        String
  measurementMethod String
  minEnvTemp        Float?
  maxEnvTemp        Float?
  date              DateTime
  notes             String?
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED, FLAGGED_BY_SYSTEM

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User?    @relation(fields: [userId], references: [id])
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id])
  flags             ModerationFlag[]
}

model ModerationFlag {
  id           String   @id @default(uuid())
  entryId      String
  reportedById String?
  reason       String
  status       String   @default("OPEN") // OPEN, DISMISSED, RESOLVED

  createdAt    DateTime @default(now())

  entry        SohEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  reportedBy   User?    @relation(fields: [reportedById], references: [id])
}

model TripLog {
  id             String   @id @default(uuid())
  userId         String
  vehicleId      String
  km             Float
  initialSoc     Float
  finalSoc       Float
  initialEnvTemp Float
  finalEnvTemp   Float
  chargeType     String?
  date           DateTime @default(now())

  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleNote {
  id             String   @id @default(uuid())
  userId         String
  vehicleId      String
  content        String
  
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
